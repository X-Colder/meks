# ============================================================
# MEKS 环境变量配置模板
# 复制此文件为 .env 并修改对应配置
# cp .env.example .env
#
# 生成随机密钥: python3 -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# ============================================================
# 应用基础配置
# ============================================================
# 必须修改！生产环境禁止使用默认值
MEKS_SECRET_KEY=change-this-to-a-secure-random-string-64-chars

# 生产环境设为 false
MEKS_DEBUG=false

# CORS 允许的前端地址，多个地址用逗号分隔
MEKS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API 限流：每分钟最大请求数（0 表示不限制）
MEKS_RATE_LIMIT_PER_MINUTE=60

# ============================================================
# PostgreSQL 数据库
# ============================================================
POSTGRES_USER=meks
# 必须修改！生产环境使用强密码
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=meks

# 连接池配置
MEKS_DB_POOL_SIZE=10
MEKS_DB_MAX_OVERFLOW=20
MEKS_DB_POOL_RECYCLE=3600

# ============================================================
# Redis 缓存/消息队列
# ============================================================
# 必须修改！生产环境使用强密码
REDIS_PASSWORD=change-this-redis-password

# ============================================================
# Milvus 向量数据库
# ============================================================
MEKS_MILVUS_HOST=milvus
MEKS_MILVUS_PORT=19530

# ============================================================
# MinIO 对象存储
# ============================================================
MINIO_ROOT_USER=meksadmin
# 必须修改！生产环境使用强密码（最少8位）
MINIO_ROOT_PASSWORD=change-this-minio-password
MEKS_MINIO_ENDPOINT=minio:9000
MEKS_MINIO_ACCESS_KEY=meksadmin
MEKS_MINIO_SECRET_KEY=change-this-minio-password
MEKS_MINIO_BUCKET=meks-documents
MEKS_MINIO_SECURE=false

# ============================================================
# vLLM 本地推理服务
# ============================================================
# Embedding 服务地址 (bge-large-zh-v1.5, 端口 8001)
MEKS_VLLM_EMBED_URL=http://vllm-embed:8001
# Chat/LLM 服务地址 (Qwen2.5-14B-Instruct, 端口 8002)
MEKS_VLLM_CHAT_URL=http://vllm-chat:8002
# 模型标识（需与 vLLM 启动参数 --model 一致）
MEKS_EMBEDDING_MODEL=/models/bge-large-zh-v1.5
MEKS_CHAT_MODEL=/models/Qwen2.5-14B-Instruct
# 模型文件目录（Docker volume 挂载点）
VLLM_MODELS_DIR=./models
# Embedding 批量大小
MEKS_EMBEDDING_BATCH_SIZE=64

# ============================================================
# Cloud LLM（可选，用于公开论文等非敏感内容）
# 警告：请勿在此文件提交真实 API Key，通过 CI/CD Secrets 注入
# ============================================================
MEKS_LLM_PROVIDER=auto
MEKS_CLOUD_PROVIDER=openai
MEKS_CLOUD_API_BASE=https://api.openai.com
MEKS_CLOUD_MODEL=gpt-4o
# OpenAI 兼容网关如果使用 Responses API，设置为 responses；默认 chat/completions
MEKS_CLOUD_WIRE_API=chat
# 也可以不写 MEKS_OPENAI_API_KEY，直接在启动前导出 OPENAI_API_KEY 或 CODEX_API_KEY
MEKS_ANTHROPIC_API_KEY=
MEKS_OPENAI_API_KEY=

# ============================================================
# 文档处理 Pipeline
# ============================================================
MEKS_CHUNK_SIZE_TOKENS=512
MEKS_CHUNK_OVERLAP_TOKENS=64
MEKS_MAX_UPLOAD_SIZE_MB=100

# ============================================================
# JWT 令牌配置
# ============================================================
MEKS_JWT_ACCESS_EXPIRE_MINUTES=15
MEKS_JWT_REFRESH_EXPIRE_DAYS=7
